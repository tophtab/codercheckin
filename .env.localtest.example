# V2EX Cookie
V2EX_COOKIE=

# NodeSeek Cookie (多账号用 & 分隔)
NODESEEK_COOKIE=

# DeepFlood Cookie (多账号用 & 分隔)
DEEPFLOOD_COOKIE=

# 一亩三分地 Cookie
ONEPOINT3ACRES_COOKIE=

# 2Captcha API Key (一亩三分地需要)
TWOCAPTCHA_APIKEY=

# Telegram 通知 (可选)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Docker / 批量运行目标，默认全部执行
CLOUDCHECKIN_IMAGE=tophtab/cloudcheckin:latest
CHECKIN_TARGETS=nodeseek,deepflood,v2ex,onepoint3acres

# Cookie Cloud（可选；如果对应站点的直接 Cookie 为空，则自动尝试下载）
COOKIE_CLOUD_URL=
COOKIE_CLOUD_UUID=
COOKIE_CLOUD_PASSWORD=
# 可留空；新实例按需设置为 aes-128-cbc-fixed
COOKIE_CLOUD_CRYPTO_TYPE=
