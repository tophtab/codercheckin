# V2EX Cookie
# 如果手动填写，建议使用单引号包裹整条 cookie，避免 .env 中的 $ 被 docker compose 当成变量插值
V2EX_COOKIE=

# NodeSeek Cookie (多账号用 & 分隔)
NODESEEK_COOKIE=

# DeepFlood Cookie (多账号用 & 分隔)
DEEPFLOOD_COOKIE=

# Telegram 通知 (可选)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Docker / 批量运行目标，默认全部执行
CLOUDCHECKIN_IMAGE=tophtab/cloudcheckin:latest
CHECKIN_TARGETS=nodeseek,deepflood,v2ex
TZ=Asia/Shanghai
CHECKIN_CRON=30 3 * * *

# Cookie Cloud（推荐；如果对应站点的直接 Cookie 为空，则自动尝试下载）
COOKIE_CLOUD_URL=
COOKIE_CLOUD_UUID=
COOKIE_CLOUD_PASSWORD=
# 可留空；新实例按需设置为 aes-128-cbc-fixed
COOKIE_CLOUD_CRYPTO_TYPE=
