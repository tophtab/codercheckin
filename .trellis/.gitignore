# Tracked Trellis project knowledge:
# workflow.md, config.yaml, spec/, tasks/, workspace/, scripts/,
# .version, and .template-hashes.json.
#
# Local-only developer identity.
.developer

# Current task pointer (each developer works on different task).
.current-task

# Session/window scoped runtime state.
.runtime/

# Ralph Loop state file
.ralph-state.json

# Agent runtime files
.agents/
.agent-log
.session-id

# Task directory runtime files.
.plan-log

# Atomic update temp files.
*.tmp

# Update backup directories.
.backup-*

# Conflict resolution temp files.
*.new

# Python cache.
**/__pycache__/
**/*.pyc
